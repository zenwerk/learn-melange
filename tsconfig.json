{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom", "dom.iterable"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "melange-output/*": ["./ui/melange-output-stub/*"]
    }
  },
  "include": [
    "ui/**/*.js",
    "ui/**/*.d.ts"
  ],
  "exclude": [
    "ui/dist",
    "ui/__tests__",
    "node_modules",
    "_build"
  ]
}
