{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom", "dom.iterable"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "melange-output/*": ["./ui/melange-output-stub/*"]
    }
  },
  "include": [
    "ui/types.d.ts",
    "ui/melange-output-stub/**/*.d.ts",
    "ui/main.js",
    "ui/language/session-client.js",
    "ui/language/language-client.js",
    "ui/terminal/cell-buffer.js",
    "ui/terminal/history.js",
    "ui/terminal/readline-keys.js",
    "ui/terminal/width.js",
    "ui/terminal/keyboard-input.js",
    "ui/terminal/line-editor.js",
    "ui/repl/completion-popup.js",
    "ui/repl/repl.js"
  ]
}
